{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "/dashboard.html"
    },
    {
      "src": "/app",
      "dest": "/dashboard.html"
    },
    {
      "src": "/app/(.*)",
      "dest": "/dashboard.html"
    },
    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/signup",
      "dest": "/signup.html"
    },
    {
      "src": "/forgot-password",
      "dest": "/forgot-password.html"
    },
    {
      "src": "/reset-password",
      "dest": "/reset-password.html"
    },
    {
      "src": "/pricing",
      "dest": "/pricing.html"
    },
    {
      "src": "/privacy",
      "dest": "/privacy.html"
    },
    {
      "src": "/privacy.html",
      "dest": "/privacy.html"
    },
    {
      "src": "/privacy-policy",
      "dest": "/privacy.html"
    },
    {
      "src": "/privacy-policy.html",
      "dest": "/privacy.html"
    },
    {
      "src": "/terms",
      "dest": "/terms.html"
    },
    {
      "src": "/terms.html",
      "dest": "/terms.html"
    },
    {
      "src": "/legal",
      "dest": "/terms.html"
    },
    {
      "src": "/legal.html",
      "dest": "/terms.html"
    },
    {
      "src": "/(meetings|scheduling|availability|contacts|workflows|integrations|routing|landing-page|analytics|admin|account)(/.*)?",
      "dest": "/dashboard.html"
    },
    {
      "src": "/(product|solutions|resources|about|contact|help-center|developers|community|blog|case-studies|security|careers|press|status|cookie-settings)",
      "dest": "/index.html"
    },
    {
      "src": "/([^/]+)/([^/]+)",
      "dest": "/booking.html"
    },
    {
      "src": "/([^/.]+)",
      "dest": "/public-landing.html"
    }
  ]
}
