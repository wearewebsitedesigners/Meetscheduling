NODE_ENV=development
PORT=8080
APP_BASE_URL=http://localhost:8080

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meetscheduling

# Auth and signing
JWT_SECRET=replace-with-strong-random-secret
PUBLIC_BOOKING_SIGNING_SECRET=replace-with-strong-random-secret

# Scheduling defaults
HOST_DEFAULT_TIMEZONE=UTC
SLOT_INTERVAL_MINUTES=15

# SMTP Email (optional for confirmations)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
SUPPORT_EMAIL=support@meetscheduling.com
AUTH_WELCOME_EMAIL_ENABLED=true
AUTH_LOGIN_EMAIL_ENABLED=true
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# ─────────────────────────────────────────────────────────────────────────────
# Google Calendar OAuth — Required for Google Calendar + Google Meet integration
# ─────────────────────────────────────────────────────────────────────────────
# Setup steps:
#   1. Go to https://console.cloud.google.com → APIs & Services → Library
#      Enable: "Google Calendar API" and "People API"
#
#   2. Go to APIs & Services → OAuth consent screen
#      - User type: External
#      - Add scopes:
#          https://www.googleapis.com/auth/calendar.events
#          https://www.googleapis.com/auth/userinfo.email
#
#   3. Go to APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
#      - Application type: Web application
#      - Authorized redirect URIs — add EXACTLY (no trailing slash):
#          https://yourdomain.com/api/integrations/google-calendar/callback
#          (also add http://localhost:8080/api/integrations/google-calendar/callback for dev)
#
#   4. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/integrations/google-calendar/callback

# ─────────────────────────────────────────────────────────────────────────────
# CRITICAL: Token encryption secret — must be set in production
# Without this, Google OAuth tokens cannot be stored/retrieved correctly and
# Google Calendar will always appear as "disconnected" after connecting.
#
# Generate a secure value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# WARNING: Never change this after users have connected Google Calendar.
#          Changing it will invalidate all stored tokens and force re-connection.
# ─────────────────────────────────────────────────────────────────────────────
INTEGRATION_TOKEN_SECRET=

# PayPal Billing
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PRODUCT_ID=
PAYPAL_BASIC_PLAN_ID=
PAYPAL_POPULAR_PLAN_ID=
PAYPAL_PRO_PLAN_ID=
